# Local app to test. For Metl local development this is usually the web app.
TARGET_URL=http://localhost:3000

# Use Azure credit for the accurate browser agent.
LLM_PROVIDER=azure
LLM_MODEL=Kimi-K2.6

# Azure OpenAI / Azure AI Foundry.
# Endpoint can be the resource root or the Azure /openai/v1 URL.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# Must match the deployment name you created in Azure, not only the model name.
AZURE_OPENAI_DEPLOYMENT=Kimi-K2.6
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_USE_RESPONSES_API=auto

# Browser behavior.
BROWSER_HEADLESS=false
BROWSER_WIDTH=1280
BROWSER_HEIGHT=900
MAX_STEPS=40

# Reports are ignored by git.
REPORT_DIR=reports
