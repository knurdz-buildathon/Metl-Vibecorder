# =========================================
# Core App
# =========================================
NODE_ENV=development
APP_URL=http://localhost:3000
APP_SECRET=replace_with_random_32_char_string

# =========================================
# Database
# =========================================
DATABASE_URL=postgresql://metlcode:metlcode@localhost:5432/metlcode?schema=public

# =========================================
# Redis
# =========================================
REDIS_URL=redis://localhost:6379

# =========================================
# GitHub OAuth (next-auth)
# =========================================
GITHUB_ID=
GITHUB_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_random_32_char_string

# =========================================
# Gemini AI
# =========================================
GEMINI_PROVIDER=developer
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Default models (check ai.google.dev for current IDs)
GEMINI_MODEL=gemini-3.1-pro-preview-customtools
GEMINI_REVIEW_MODEL=gemini-3.1-pro-preview
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_STABLE_FALLBACK_MODEL=gemini-2.5-pro
GEMINI_MAX_OUTPUT_TOKENS=8192

# =========================================
# Agent Service
# =========================================
AGENT_SERVICE_URL=http://localhost:8000

# =========================================
# VibeCoder config
# =========================================
VIBECODER_MAX_REPAIR_ATTEMPTS=2

# =========================================
# Python Agent CORS
# =========================================
CORS_ORIGINS=http://localhost:3000

# =========================================
# Workspaces
# =========================================
WORKSPACE_PROVIDER=local-docker
WORKSPACE_BASE_DIR=./workspace-volumes

# =========================================
# OpenVSCode Server
# =========================================
CODE_SERVER_PASSWORD=metlcode
