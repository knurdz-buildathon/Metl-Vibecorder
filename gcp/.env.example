# Copy to .env and paste your GCP / Gemini API key.
#
# Any one of these names works:
GEMINI_API_KEY=
GOOGLE_API_KEY=
GCP_CLOUD_API_KEY=

# Agent Platform / Vertex AI Express mode API keys need vertex-express.
# Normal AI Studio Gemini keys can use gemini-developer.
GENAI_BACKEND=vertex-express

# Gemini model to test. gemini-2.5-flash is the safest starter for Vertex Express.
GEMINI_MODEL=gemini-2.5-flash

# Optional chatbot behavior.
BOT_NAME=Metl GCP Bot
SYSTEM_PROMPT=You are a concise, helpful chatbot for testing a Google Cloud Gemini API key.
